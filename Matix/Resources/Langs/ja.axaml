<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="StrTheme">テーマ</sys:String>
    <sys:String x:Key="StrQuality">音質</sys:String>
    <sys:String x:Key="StrLanguage">言語</sys:String>
    <sys:String x:Key="StrAbout">アプリについて</sys:String>
    <sys:String x:Key="StrInProgress">開発中...</sys:String>
    <sys:String x:Key="StrGithubRepo">GitHubリポジトリ</sys:String>
    <sys:String x:Key="StrChooseFolder">フォルダを選択</sys:String>
    <sys:String x:Key="StrOpenFile">ファイルを開く</sys:String>
</ResourceDictionary>
