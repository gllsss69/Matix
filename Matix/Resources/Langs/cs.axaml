<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="StrTheme">Téma</sys:String>
    <sys:String x:Key="StrQuality">Kvalita</sys:String>
    <sys:String x:Key="StrLanguage">Jazyk</sys:String>
    <sys:String x:Key="StrAbout">O aplikaci</sys:String>
    <sys:String x:Key="StrInProgress">Probíhá...</sys:String>
    <sys:String x:Key="StrGithubRepo">GitHub Repozitář</sys:String>
    <sys:String x:Key="StrChooseFolder">Vybrat složku</sys:String>
    <sys:String x:Key="StrOpenFile">Otevřít soubor</sys:String>
</ResourceDictionary>
