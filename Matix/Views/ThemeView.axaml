<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:vm="clr-namespace:Matix.ViewModels"
             x:Class="Matix.Views.ThemeView"
             x:DataType="vm:ThemeViewModel"
             Background="#F3EDF7">

    <UserControl.Styles>
        <Style Selector="Button.rippleBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6750A4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Top App Bar -->
        <Grid Height="64" VerticalAlignment="Top" Grid.Row="0">
            <controls:Card Width="48" Height="48" CornerRadius="24" Padding="0"
                           Background="#EADDFF" HorizontalAlignment="Left" Margin="16,8">
                <Button Classes="rippleBtn" Width="48" Height="48" CornerRadius="24"
                        Command="{Binding GoBackCommand}">
                    <materialIcons:MaterialIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="#6750A4"/>
                </Button>
            </controls:Card>
            <TextBlock Text="Theme" FontSize="22" FontWeight="SemiBold" Foreground="#1D1B20"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Centered placeholder -->
        <Grid Grid.Row="1" Background="Transparent">
            <TextBlock Text="In progress..."
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#6750A4"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
