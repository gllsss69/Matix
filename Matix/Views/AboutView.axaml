<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:vm="clr-namespace:Matix.ViewModels"
             x:Class="Matix.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <!-- Top App Bar -->
        <Grid Height="64" VerticalAlignment="Top">
            <controls:Card Width="48" Height="48" CornerRadius="24" Padding="0"
                           Background="{DynamicResource PrimaryContainer}" HorizontalAlignment="Left" Margin="16,8">
                <Button Classes="rippleBtn" Width="48" Height="48" CornerRadius="24"
                        Command="{Binding GoBackCommand}">
                    <materialIcons:MaterialIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource PrimaryColor}"/>
                </Button>
            </controls:Card>
            <TextBlock Text="About" Classes="Title"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- About Content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <controls:Card Width="120" Height="120" CornerRadius="40" Padding="0"
                           Background="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,16">
                <materialIcons:MaterialIcon Kind="MusicNote" Width="60" Height="60" Foreground="{DynamicResource PrimaryContainer}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </controls:Card>

            <TextBlock Text="{Binding AppName}" Classes="Title" FontSize="32"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Version}" Classes="Subtitle"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding Description}" Classes="Body"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
            <TextBlock Text="{Binding Tech}" Classes="Body"
                       HorizontalAlignment="Center"/>

            <controls:Card CornerRadius="16" Padding="0" Background="{DynamicResource PrimaryContainer}"
                           HorizontalAlignment="Center" Margin="0,32,0,0">
                <Button Classes="rippleBtn" Height="48" CornerRadius="16" Padding="24,0"
                        Command="{Binding OpenGitHubCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="Github" Width="20" Height="20" Foreground="{DynamicResource PrimaryColor}"/>
                        <TextBlock Text="GitHub Repository" VerticalAlignment="Center"
                                   Classes="Subtitle"/>
                    </StackPanel>
                </Button>
            </controls:Card>
        </StackPanel>
    </Grid>
</UserControl>
