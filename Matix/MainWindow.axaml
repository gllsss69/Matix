<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Matix.ViewModels"
        xmlns:views="clr-namespace:Matix.Views"
        x:Class="Matix.MainWindow"
        x:DataType="vm:AppViewModel"
        Title="Matix Player"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="660"
        Background="#D1C4E9"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
            <views:PlayerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LanguageViewModel}">
            <views:LanguageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QualityViewModel}">
            <views:QualityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThemeViewModel}">
            <views:ThemeView/>
        </DataTemplate>
    </Window.DataTemplates>

    <ContentControl Content="{Binding CurrentPage}"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"/>

</Window>