<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Matix.ViewModels"
        xmlns:views="clr-namespace:Matix.Views"
        x:Class="Matix.MainWindow"
        x:DataType="vm:AppViewModel"
        Title="Matix Player"
        Width="1000" Height="700"
        MinWidth="{Binding AppMinWidth}" MinHeight="660"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
            <views:PlayerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LanguageViewModel}">
            <views:LanguageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QualityViewModel}">
            <views:QualityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThemeViewModel}">
            <views:ThemeView/>
        </DataTemplate>
    </Window.DataTemplates>

    <TransitioningContentControl Content="{Binding CurrentPage}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch">
        <TransitioningContentControl.PageTransition>
            <CrossFade Duration="0:0:0.25" />
        </TransitioningContentControl.PageTransition>
    </TransitioningContentControl>

</Window>